<Window x:Class="TaskManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManager.UI"
        mc:Ignorable="d"
        Title="MainWindow" Width="1280" Height="720"
        WindowStartupLocation="CenterScreen">
 
    
    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Background="#441375"
              Foreground="#FFFFFF"
              Height="22"
              FontSize="12pt">
            <MenuItem Header="File">
                <MenuItem Header="New Task">
                </MenuItem>
                <MenuItem Header="Open/Import"></MenuItem>
                <MenuItem Header="Export"></MenuItem>
                <MenuItem Header="Settings"></MenuItem>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo"></MenuItem>
                <MenuItem Header="Redo"></MenuItem>
                <MenuItem Header="Copy"></MenuItem>
                <MenuItem Header="Paste"></MenuItem>
                <MenuItem Header="Edit Task"></MenuItem>
                <MenuItem Header="Delete Task"></MenuItem>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Dark/Light Mode"></MenuItem>
                <MenuItem Header="Refresh"></MenuItem>
                <MenuItem Header="Show/Hide Completed Task"></MenuItem>
                <MenuItem Header="Sort By">
                    <MenuItem Header="Date"></MenuItem>
                    <MenuItem Header="Priority"></MenuItem>
                </MenuItem>
                <MenuItem Header="Filter"></MenuItem>              
            </MenuItem>
        </Menu>
        <Border DockPanel.Dock="Top" Background="#2d0a5e" Padding="10,6" BorderThickness="0">
            <WrapPanel>
                <Border Style="{StaticResource FilterControl}">
                    <TextBox x:Name="Search" 
                             Width="200" 
                             Margin="10" 
                             Background="Transparent"
                             Foreground="#FFFFFF"
                             BorderThickness="0"
                             Padding="4"/>
                </Border>
                <ComboBox x:Name="cmbState" Width="120" Foreground="#FFFFFF" BorderThickness="0" Margin="10"/>
                <ComboBox x:Name="cmbCategory" Width="120" Foreground="#FFFFFF" BorderThickness="0" Margin="10"/>
                <ComboBox x:Name="cmbPriority" Width="120" Foreground="#FFFFFF" BorderThickness="0" Margin="10"/>
                <ComboBox x:Name="cmbSort" Width="120" Foreground="#FFFFFF" BorderThickness="0" Margin="10"/>
            </WrapPanel>
        </Border>
        <ScrollViewer Background="#1a0038">
            <ItemsControl x:Name="taskList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Height="260" Margin="10" Background="#570a5e" CornerRadius="12">
                            <StackPanel Margin="12">
                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" Foreground="#cccccc" FontSize="11"/>
                                <TextBlock Text="{Binding Deadline}" Foreground="#aaaaaa" FontSize="10"/>
                                <TextBlock Text="{Binding Priority}" Foreground="#aaaaaa" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
    
</Window>
