<Window x:Class="TaskManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManager.UI"
        mc:Ignorable="d"
        Title="MainWindow" Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource PrimaryBrush}"
              Foreground="{DynamicResource ForegroundBrush}"
              Height="22"
              FontSize="12pt">
            <MenuItem Header="File">
                <MenuItem Header="New Task" Click="NewTask_Click"/>
                <MenuItem Header="Open" Click="OpenFile"/>
                <MenuItem Header="Export" Click="Export"/>
                <MenuItem Header="Settings" Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo"/>
                <MenuItem Header="Redo"/>
                <MenuItem Header="Copy"/>
                <MenuItem Header="Paste"/>
                <MenuItem Header="Edit Task"/>
                <MenuItem Header="Delete Task"/>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Dark/Light Mode"/>
                <MenuItem Header="Refresh"/>
                <MenuItem Header="Show/Hide Completed Task"/>
                <MenuItem Header="Sort By">
                    <MenuItem Header="Date"/>
                    <MenuItem Header="Priority"/>
                </MenuItem>
                <MenuItem Header="Filter"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" Background="{DynamicResource SecondaryBrush}" Padding="10,6" BorderThickness="0">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="+ New Task"
                        Click="NewTask_Click"
                        Margin="10"
                        Padding="12,4"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderThickness="0"/>
                <WrapPanel>
                    <Border Style="{DynamicResource FilterControl}">
                        <TextBox x:Name="Search" Text="Search"
                                 Width="200"
                                 Margin="10"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="4"
                                 TextChanged="Search_TextChanged"/>
                    </Border>
                    <ComboBox x:Name="cmbState" Width="120" Margin="10" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All States" IsSelected="True"/>
                        <ComboBoxItem Content="New"/>
                        <ComboBoxItem Content="InProgress"/>
                        <ComboBoxItem Content="Completed"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbCategory" Width="120" Margin="10" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Categories" IsSelected="True"/>
                        <ComboBoxItem Content="Work"/>
                        <ComboBoxItem Content="Study"/>
                        <ComboBoxItem Content="Home"/>
                        <ComboBoxItem Content="Personal"/>
                        <ComboBoxItem Content="Hobby"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbPriority" Width="120" Margin="10" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Priorities" IsSelected="True"/>
                        <ComboBoxItem Content="Low"/>
                        <ComboBoxItem Content="Medium"/>
                        <ComboBoxItem Content="High"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbSort" Width="120" Margin="10" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="Date" IsSelected="True"/>
                        <ComboBoxItem Content="Priority"/>
                        <ComboBoxItem Content="Deadline"/>
                    </ComboBox>
                </WrapPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Background="{DynamicResource BackgroundBrush}">
            <ItemsControl x:Name="taskList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Height="260" Margin="10"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="12">
                            <Grid Margin="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="{Binding Title}"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="15" FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Margin="0,0,6,0"/>
                                <TextBlock Grid.Row="1" 
                                           Text="{Binding Description}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           MaxHeight="50"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,6,0"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="10" Padding="8,3" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Priority}" Foreground="{DynamicResource ForegroundBrush}" FontSize="10"/>
                                    </Border>
                                    <Border Background="{DynamicResource SecondaryBrush}" CornerRadius="10" Padding="8,3">
                                        <TextBlock Text="{Binding Category}" Foreground="{DynamicResource ForegroundBrush}" FontSize="10"/>
                                    </Border>
                                </StackPanel>
                                <Grid Grid.Row="3" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="DEADLINE" Foreground="{DynamicResource SubtextBrush}" FontSize="9" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Deadline, StringFormat=dd/MM/yyyy}" Foreground="{DynamicResource ForegroundBrush}" FontSize="11"/> 
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="STATUS" Foreground="{DynamicResource SubtextBrush}" FontSize="9" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding State}" Foreground="{DynamicResource ForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="✏ Edit"
                                            Tag="{Binding Id}"
                                               Click="EditTask_Click"
                                               Padding="0,6"/>
                                    <Button Grid.Column="2" Content="🗑 Delete"
                                            Tag="{Binding Id}"
                                            Click="DeleteTask_Click"
                                            Background="{DynamicResource SecondaryBrush}"
                                            Padding="0,6"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</Window>