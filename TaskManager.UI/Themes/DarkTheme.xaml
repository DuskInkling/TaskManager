<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBrush"       Color="#1a1a2e"/>
    <SolidColorBrush x:Key="SecondaryBrush"     Color="#16213e"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="#0f3460"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="#1a4a7a"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#0a2440"/>
    <SolidColorBrush x:Key="BackgroundBrush"    Color="#0d0d1a"/>
    <SolidColorBrush x:Key="ForegroundBrush"    Color="#e0e0e0"/>
    <SolidColorBrush x:Key="SubtextBrush"       Color="#888888"/>

</ResourceDictionary>