<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBrush"       Color="#5c6bc0"/>
    <SolidColorBrush x:Key="SecondaryBrush"     Color="#e8eaf6"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="#7986cb"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="#9fa8da"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#3f51b5"/>
    <SolidColorBrush x:Key="BackgroundBrush"    Color="#f5f5f5"/>
    <SolidColorBrush x:Key="ForegroundBrush"    Color="#212121"/>
    <SolidColorBrush x:Key="SubtextBrush"       Color="#757575"/>

</ResourceDictionary>